{
  "name": "serviceforge-prisma",
  "version": "1.0.0",
  "description": "An industrialized, high-performance Prisma ORM boilerplate and utility toolkit containing connection pooling, strict base controllers, global middlewares, and unified authentication handlers mapped for scalable microservice architectures.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "prisma/schema.prisma"
  ],
  "bin": {
    "sf-prisma": "./bin/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "prisma",
    "database",
    "microservices",
    "industrial"
  ],
  "author": "Ranajit Karmakar",
  "license": "MIT",
  "type": "module",
  "peerDependencies": {
    "@prisma/client": "^7.7.0",
    "prisma": "^7.7.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.2",
    "prisma": "^7.7.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@prisma/client": "^7.7.0",
    "chalk": "^5.6.2",
    "express": "^5.2.1",
    "inquirer": "^13.4.1",
    "jsonwebtoken": "^9.0.3",
    "path": "^0.12.7",
    "ts-node": "^10.9.2",
    "winston": "^3.19.0",
    "zod": "^3.24.2"
  }
}
